NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Base64 encoding of the complete Firebase Admin service-account JSON file.
# Keep this value server-side only. Never add it to frontend environment files.
FIREBASE_SERVICE_ACCOUNT_BASE64=your-base64-encoded-service-account-json

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_EMAIL=your-smtp-email
SMTP_PASSWORD=your-smtp-password

GEMINI_API_KEY=your-gemini-api-key
